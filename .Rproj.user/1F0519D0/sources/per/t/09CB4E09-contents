fitness <- function(k, data){
  - kmeans(data, centers = k, nstart = 20)$tot.withinss
}

ga_kmeans <- function(data){
  population <- sample(2:10,20,replace = TRUE)
  for (g in 1:50) {
    scores <- sapply(population, fitness, data = data)
    population <- population[order(scores, decreasing = TRUE)][1:10]
    population <- c(population, population+sample(c(-1,1),10,TRUE))
  }
  population[which.max(sapply(population,fitness, data=data))]
}


