install.packages("cluster")
library(cluster)

wss <- sapply(2:10, function(k) {
  kmeans(data, centers = k, nstart = 10)$tot.withinss
})

plot(1:10, wss, type = "b",
    xlab = "K", ylab = "inertie intra-class")      #il faut choisir le minimum

#############################################################

sil <- sapply(2:10, function(k) {
  km <- kmeans(data, centers = k, nstart = 10)
  mean(silhouette(km$cluster, dist(data))[,3])
})

plot(2:10, sil, type = "b",
     xlab = "K", ylab = "Silhouette moyenne")     #il faut choisir le maximum 

